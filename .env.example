# Volimox — Environment Variables
# Copy this to .env.local and fill in your values

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# --- Proton live booking bridge ---
# Server-side only. Do not expose these through NEXT_PUBLIC_* variables.
PROTON_API_BASE_URL=https://www.protonlimo.com
PROTON_API_KEY=your-proton-web-demo-shared-secret

# --- Gemini Live voice session ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# --- Volimox global demonstration bridge ---
# Google Routes must be enabled for worldwide distance and duration lookups.
GOOGLE_MAPS_API_KEY=your-server-side-google-maps-key
VOLIMOX_DEMO_LINK_SECRET=replace-with-a-32-byte-random-secret
VOLIMOX_DEMO_BASE_RATE=36
VOLIMOX_DEMO_PER_MILE_RATE=3.25

# --- Email (Gmail SMTP via App Password) ---
# Your Gmail address
SMTP_USER=your.email@gmail.com
# Gmail App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_PASS=your-16-char-app-password

# Alternative SMTP names used by the production environment
EMAIL_USER=
EMAIL_PASS=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Where to send lead notifications (defaults to SMTP_USER if not set)
NOTIFICATION_EMAIL=you@volimox.ai

# Dedicated Volimox Firebase project ID guardrail
VOLIMOX_FIREBASE_PROJECT_ID=volimox-platform
VOLIMOX_DEMO_TENANT_ID=volimox-demo

# Rate-limit key HMAC secret (falls back to VOLIMOX_DEMO_LINK_SECRET if unset)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VOLIMOX_RATE_LIMIT_SECRET=

# Retell webhook signature verification secret
RETELL_WEBHOOK_SECRET=

# Leave blank to use the Firebase project's default Firestore database
VOLIMOX_FIRESTORE_DATABASE_ID=
RETELL_DEMO_VOICE_AGENT_ID=
RETELL_DEMO_FLOW_ID=
VOLIMOX_DEMO_PUBLIC_URL=https://volimox.com

# Optional dedicated Volimox sender. When set, demo calls and SMS use this number instead of Proton's sender.
VOLIMOX_DEMO_PHONE_NUMBER=
